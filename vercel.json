    "api/cron/snapshot-daily.ts": {
      "maxDuration": 300
    },
    "api/cron/wapify-export-historical.ts": {
      "maxDuration": 300
    },
    "api/cron/backup-monthly.ts": {
      "maxDuration": 300
    },
    "api/cron/refresh-rotacion.ts": {
      "maxDuration": 60
    },
    "api/cron/refresh-analitica.ts": {
      "maxDuration": 60
