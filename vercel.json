    "api/cron/alertas-stock-bajo.ts": {
      "maxDuration": 30
    },
    "api/inventario/operaciones.ts": {
      "maxDuration": 10
    },
    "api/inventario/rotacion.ts": {
      "maxDuration": 10
    },
    "api/inventario/movimientos.ts": {
      "maxDuration": 10
    },
    "api/admin/restore.ts": {
