    "api/auto-prompt.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/webhook?mode=cron",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/fetch-provider-usage",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/refresh-meta-token",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/sync-wapify-cache",
      "schedule": "30 12 * * *"
    },
    {
      "path": "/api/cron/enrich-contacts",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/refresh-rotacion",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/snapshot-daily",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/wapify-export-historical",
      "schedule": "30 10 * * *"
    },
    {
      "path": "/api/cron/alertas-stock-bajo",
      "schedule": "15 * * * *"
    },
    {
      "path": "/api/cron/backup-monthly",
      "schedule": "0 8 1 * *"
    },
    {
      "path": "/api/cron/refresh-analitica",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/refresh-clinica",
      "schedule": "30 * * * *"
    },
    {
      "path": "/api/cron/refresh-marketing",
      "schedule": "45 * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/analitica.html",
      "destination": "/public/analitica.html"
    },
    {
      "source": "/analitica",
      "destination": "/public/analitica.html"
    },
    {
      "source": "/inventario.html",
      "destination": "/public/inventario.html"
    },
    {
      "source": "/inventario",
      "destination": "/public/inventario.html"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/public/index.html"
    }
  ]
}
