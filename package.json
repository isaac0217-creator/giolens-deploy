{
  "name": "giolens-dashboard",
  "version": "1.0.0",
  "description": "GioLens Vision Care CRM Dashboard",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vercel dev",
    "deploy": "vercel --prod",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:agents": "vitest run agents/",
    "test:evals": "node evals/run-all.js",
    "smoke:sentry": "node --env-file=.env.local scripts/sentry-smoke-e2e.mjs",
    "smoke:agents": "node scripts/sim-agents.mjs"
  },
  "dependencies": {
    "@sentry/node": "^10.53.1",
    "@supabase/supabase-js": "^2.106.0",
    "inngest": "^3.27.0"
  },
  "devDependencies": {
    "vercel": "^37.0.0",
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0"
  }
}
